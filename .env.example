APP_NAME=optic-rag-demo
DEBUG=true
DATABASE_URL=sqlite:///./optic_rag.db
HF_TOKEN=

LLM_PROVIDER=hf
LLM_API_BASE=https://router.huggingface.co/v1
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct:together

EMBEDDING_PROVIDER=hf
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# If using Google Gemini:
# LLM_PROVIDER=google
# GOOGLE_GENAI_API_KEY=
# GOOGLE_MODEL_NAME=gemini-2.5-flash
#
# If using Google for embeddings (recommended if HF embedding model isn't supported):
# EMBEDDING_PROVIDER=google
# GOOGLE_EMBEDDING_MODEL_NAME=gemini-embedding-001
